# Variáveis de Ambiente — FinAgent
# Copie este arquivo para .env e preencha os valores reais
# NUNCA comite o arquivo .env no Git!

# ─── Django ──────────────────────────────────────────────────
SECRET_KEY=django-insecure-troque-por-uma-chave-secreta-forte-aqui
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ─── Banco de Dados (desenvolvimento = SQLite, produção = PostgreSQL) ───
# Deixe em branco para usar SQLite (padrão)
DB_ENGINE=django.db.backends.sqlite3
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=finagent
# DB_USER=finagent
# DB_PASSWORD=senha-segura
# DB_HOST=db
# DB_PORT=5432

# ─── Claude API (Anthropic) ──────────────────────────────────
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-coloque-sua-chave-aqui
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Redis / Celery (opcional — só se usar tasks em background) ──
